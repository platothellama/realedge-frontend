PORT=8000
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=realestate_db
DB_USERNAME=root
DB_PASSWORD=123456
NODE_ENV=development
JWT_SECRET=super-secret-key-for-real-estate-erp
JWT_EXPIRE=90d
OPENAI_API_KEY=your-openai-api-key-here

# Embedding Configuration
# Set to 'true' to use local embeddings (no API costs)
# Set to 'false' or omit to use OpenAI embeddings
USE_LOCAL_EMBEDDINGS=false

# OpenAI embedding model: text-embedding-3-small, text-embedding-3-large, or text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@yourdomain.com
API_URL=http://localhost:8000
